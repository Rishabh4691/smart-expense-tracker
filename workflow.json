{
  "name": "Smart Expense Tracker",
  "nodes": [
    {
      "parameters": {
        "updates": ["message"],
        "additionalFields": {}
      },
      "name": "Telegram Trigger",
      "type": "n8n-nodes-base.telegramTrigger",
      "position": [240, 300]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{ $json.message.photo }}",
              "operation": "isNotEmpty"
            }
          ]
        }
      },
      "name": "Is it a photo?",
      "type": "n8n-nodes-base.if",
      "position": [460, 300]
    },
    {
      "parameters": {
        "url": "=https://api.telegram.org/bot{{ $env.TELEGRAM_BOT_TOKEN }}/getFile",
        "qs": {
          "file_id": "={{ $json.message.photo.slice(-1)[0].file_id }}"
        }
      },
      "name": "Get Photo File",
      "type": "n8n-nodes-base.httpRequest",
      "position": [680, 200]
    },
    {
      "parameters": {
        "url": "=https://api.telegram.org/file/bot{{ $env.TELEGRAM_BOT_TOKEN }}/{{ $json.result.file_path }}"
      },
      "name": "Download Photo",
      "type": "n8n-nodes-base.httpRequest",
      "position": [900, 200],
      "typeVersion": 1
    },
    {
      "parameters": {
        "model": "llama-3.2-11b-vision-preview",
        "messages": {
          "values": [
            {
              "role": "user",
              "content": "=Look at this receipt image and extract: 1) merchant name, 2) total amount, 3) currency, 4) date, 5) category (Food/Coffee/Transport/Groceries/Health/Entertainment/Subscriptions/Home/Education/Other). Reply ONLY in this exact JSON format with no extra text: {\"merchant\": \"\", \"amount\": 0.00, \"currency\": \"EUR\", \"date\": \"YYYY-MM-DD\", \"category\": \"\"}"
            }
          ]
        }
      },
      "name": "Extract Expense with Groq",
      "type": "@n8n/n8n-nodes-langchain.lmChatGroq",
      "position": [1120, 200]
    },
    {
      "parameters": {
        "operation": "append",
        "sheetId": "={{ $env.GOOGLE_SHEET_ID }}",
        "range": "Sheet1!A:F",
        "valueInputMode": "USER_ENTERED",
        "values": {
          "values": [
            {
              "value": "={{ JSON.parse($json.message.content).date }}"
            },
            {
              "value": "={{ JSON.parse($json.message.content).merchant }}"
            },
            {
              "value": "={{ JSON.parse($json.message.content).amount }}"
            },
            {
              "value": "={{ JSON.parse($json.message.content).currency }}"
            },
            {
              "value": "={{ JSON.parse($json.message.content).category }}"
            }
          ]
        }
      },
      "name": "Log to Google Sheets",
      "type": "n8n-nodes-base.googleSheets",
      "position": [1340, 200]
    },
    {
      "parameters": {
        "chatId": "={{ $env.TELEGRAM_CHAT_ID }}",
        "text": "=✅ Logged!\n\n🏪 {{ JSON.parse($node['Extract Expense with Groq'].json.message.content).merchant }}\n💶 {{ JSON.parse($node['Extract Expense with Groq'].json.message.content).amount }} {{ JSON.parse($node['Extract Expense with Groq'].json.message.content).currency }}\n📂 {{ JSON.parse($node['Extract Expense with Groq'].json.message.content).category }}\n📅 {{ JSON.parse($node['Extract Expense with Groq'].json.message.content).date }}"
      },
      "name": "Confirm via Telegram",
      "type": "n8n-nodes-base.telegram",
      "position": [1560, 200]
    },
    {
      "parameters": {
        "rule": {
          "interval": [{ "field": "cronExpression", "expression": "0 18 * * 0" }]
        }
      },
      "name": "Every Sunday 6pm",
      "type": "n8n-nodes-base.scheduleTrigger",
      "position": [240, 500]
    },
    {
      "parameters": {
        "operation": "read",
        "sheetId": "={{ $env.GOOGLE_SHEET_ID }}",
        "range": "Sheet1!A:F"
      },
      "name": "Read This Week Expenses",
      "type": "n8n-nodes-base.googleSheets",
      "position": [460, 500]
    },
    {
      "parameters": {
        "model": "llama3-8b-8192",
        "messages": {
          "values": [
            {
              "role": "user",
              "content": "=Here is this week's expense data: {{ JSON.stringify($json) }}. Write a friendly weekly spending summary with total, breakdown by category using emojis, and one short observation about spending habits. Keep it conversational and under 200 words."
            }
          ]
        }
      },
      "name": "Generate Weekly Summary",
      "type": "@n8n/n8n-nodes-langchain.lmChatGroq",
      "position": [680, 500]
    },
    {
      "parameters": {
        "chatId": "={{ $env.TELEGRAM_CHAT_ID }}",
        "text": "=💸 Weekly Expense Report\n\n{{ $json.message.content }}"
      },
      "name": "Send Weekly Report",
      "type": "n8n-nodes-base.telegram",
      "position": [900, 500]
    }
  ],
  "connections": {
    "Telegram Trigger": { "main": [[{ "node": "Is it a photo?" }]] },
    "Is it a photo?": { "main": [[{ "node": "Get Photo File" }], []] },
    "Get Photo File": { "main": [[{ "node": "Download Photo" }]] },
    "Download Photo": { "main": [[{ "node": "Extract Expense with Groq" }]] },
    "Extract Expense with Groq": { "main": [[{ "node": "Log to Google Sheets" }]] },
    "Log to Google Sheets": { "main": [[{ "node": "Confirm via Telegram" }]] },
    "Every Sunday 6pm": { "main": [[{ "node": "Read This Week Expenses" }]] },
    "Read This Week Expenses": { "main": [[{ "node": "Generate Weekly Summary" }]] },
    "Generate Weekly Summary": { "main": [[{ "node": "Send Weekly Report" }]] }
  }
}
